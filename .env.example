FAL_API_KEY=

# WeChat Login
NEXT_PUBLIC_WECHAT_SCAN_URL=

# E2E Test credentials (optional — only needed for authenticated E2E tests)
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
